{
  "name": "spatialroom-monorepo",
  "version": "1.0.0",
  "description": "SpatialRoom real-time virtual environment with spatial audio",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "install:server": "npm --prefix server install",
    "install:client": "npm --prefix client install --legacy-peer-deps",
    "install-all": "npm run install:server && npm run install:client",
    "server": "npm --prefix server start",
    "client": "npm --prefix client run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
